# ── Models ────────────────────────────────────────────────────────
# Comma-separated list of model ids to load at startup. Each id must exist
# in the built-in registry (see app/models_registry.py) or be supplied via
# MODELS_FILE.
ENABLED_MODELS=orpheus-en,orpheus-tr
# Default model id used when a request omits ``model``.
DEFAULT_MODEL=orpheus-en
# Optional path to a JSON file that defines extra profiles or overrides
# built-in ones. Format: list of objects with ``id``, ``model_name``,
# ``tokenizer_name``, ``voices``, ``default_voice`` etc.
MODELS_FILE=

# ── vLLM engine defaults ──────────────────────────────────────────
DTYPE=bfloat16
MAX_MODEL_LEN=2048
# Total VRAM fraction for vLLM across all loaded models. The per-engine
# share is GPU_MEMORY_UTILIZATION / len(ENABLED_MODELS) by default, or
# override explicitly with PER_MODEL_GPU_MEMORY_UTILIZATION.
GPU_MEMORY_UTILIZATION=0.90
PER_MODEL_GPU_MEMORY_UTILIZATION=0

# ── vLLM engine tuning ────────────────────────────────────────────
MAX_NUM_SEQS=64
MAX_NUM_BATCHED_TOKENS=4096
ENABLE_CHUNKED_PREFILL=true
ENABLE_PREFIX_CACHING=true
BLOCK_SIZE=16

# ── Sampling defaults ─────────────────────────────────────────────
TEMPERATURE=0.4
TOP_P=0.9
MAX_TOKENS=1200
REPETITION_PENALTY=1.1
STOP_TOKEN_IDS=128258

# ── SNAC decoder ──────────────────────────────────────────────────
SNAC_MODEL_NAME=hubertsiuzdak/snac_24khz
# Leave empty for auto-detect (cuda if available, else cpu).
# Set to "cuda:1" to place SNAC on a second GPU for better concurrency.
SNAC_DEVICE=

# ── Streaming ─────────────────────────────────────────────────────
MIN_FRAMES_FIRST=1
MIN_FRAMES_SUBSEQUENT=4

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
