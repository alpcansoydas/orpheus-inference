# ── Model ─────────────────────────────────────────────────────────
MODEL_NAME=canopylabs/orpheus-3b-0.1-ft
TOKENIZER_NAME=canopylabs/orpheus-3b-0.1-pretrained
DTYPE=bfloat16
MAX_MODEL_LEN=2048
GPU_MEMORY_UTILIZATION=0.90

# ── vLLM engine tuning ────────────────────────────────────────────
MAX_NUM_SEQS=64
MAX_NUM_BATCHED_TOKENS=4096
ENABLE_CHUNKED_PREFILL=true
ENABLE_PREFIX_CACHING=true
BLOCK_SIZE=16

# ── Sampling defaults ─────────────────────────────────────────────
TEMPERATURE=0.4
TOP_P=0.9
MAX_TOKENS=1200
REPETITION_PENALTY=1.1
STOP_TOKEN_IDS=128258

# ── SNAC decoder ──────────────────────────────────────────────────
SNAC_MODEL_NAME=hubertsiuzdak/snac_24khz
# Leave empty for auto-detect (cuda if available, else cpu).
# Set to "cuda:1" to place SNAC on a second GPU for better concurrency.
SNAC_DEVICE=

# ── Streaming ─────────────────────────────────────────────────────
MIN_FRAMES_FIRST=1
MIN_FRAMES_SUBSEQUENT=4

# ── Voices ────────────────────────────────────────────────────────
AVAILABLE_VOICES=tara,zoe,jess,zac,leo,mia,julia,leah
DEFAULT_VOICE=tara

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
